# Copie ce fichier en .env et remplis les valeurs

# Token du bot Discord
# Récupère-le sur : https://discord.com/developers/applications
# Onglet Bot → Reset Token
DISCORD_TOKEN=

# ID du serveur Discord sur lequel le bot est actif
# Clic droit sur ton serveur → Copier l'identifiant (active le mode développeur dans les paramètres Discord)
GUILD_ID=

# Chemin vers le fichier de base de données SQLite
DB_PATH=

# Saltrounds pour bcrypt (10 = bon équilibre sécurité/vitesse)
BCRYPT_ROUNDS=
